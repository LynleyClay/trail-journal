# Credentials for the admin panel (/admin/*) and any content-mutating API
# requests (POST/PUT/DELETE). Reads (home, map, individual posts) stay public.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Vercel Blob token. When set, uploaded photos and post data are stored in
# Vercel Blob so the admin panel works in production (the deployed
# filesystem is read-only). When unset, everything falls back to the local
# content/ and public/photos/ directories for local development.
BLOB_READ_WRITE_TOKEN=
